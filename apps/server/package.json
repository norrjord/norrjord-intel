{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "discover": "bun src/jobs/discover.ts",
    "dedup": "bun src/jobs/dedup.ts",
    "discover-allabolag": "bun src/jobs/discover-allabolag.ts",
    "enrich": "bun src/jobs/enrich.ts",
    "check-activity": "bun src/jobs/check-activity.ts",
    "find-emails": "bun src/jobs/find-emails.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@ai-sdk/devtools": "^0.0.2",
    "@ai-sdk/google": "^3.0.1",
    "@anthropic-ai/sdk": "^0.74.0",
    "@norrjord-intel/api": "workspace:*",
    "@norrjord-intel/auth": "workspace:*",
    "@norrjord-intel/db": "workspace:*",
    "@norrjord-intel/env": "workspace:*",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "ai": "catalog:",
    "better-auth": "catalog:",
    "cheerio": "^1.2.0",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "resend": "^6.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@norrjord-intel/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "catalog:"
  }
}
